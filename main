<!-- ============================================================
     JAVASCRIPT — Toàn bộ logic ứng dụng
     ============================================================ -->
<script>
/* ============================================================
   DỮ LIỆU TỪ VỰNG — Mảng 10 từ thông dụng nhất
   Thêm/sửa từ ở đây để cập nhật toàn bộ ứng dụng
   ============================================================ */
const vocabulary = [
  {
    word: "Abundant",
    phonetic: "/əˈbʌndənt/",
    type: "Tính từ",
    meaning: "Phong phú, dồi dào",
    example: "Nature is <em>abundant</em> in this tropical region.",
    emoji: "🌿"
  },
  {
    word: "Brilliant",
    phonetic: "/ˈbrɪliənt/",
    type: "Tính từ",
    meaning: "Xuất sắc, rực rỡ",
    example: "She gave a <em>brilliant</em> presentation to the board.",
    emoji: "✨"
  },
  {
    word: "Curious",
    phonetic: "/ˈkjʊəriəs/",
    type: "Tính từ",
    meaning: "Tò mò, hiếu kỳ",
    example: "Children are naturally <em>curious</em> about the world.",
    emoji: "🔍"
  },
  {
    word: "Dedicate",
    phonetic: "/ˈdedɪkeɪt/",
    type: "Động từ",
    meaning: "Cống hiến, dành cho",
    example: "She <em>dedicates</em> her life to helping others.",
    emoji: "❤️"
  },
  {
    word: "Efficient",
    phonetic: "/ɪˈfɪʃənt/",
    type: "Tính từ",
    meaning: "Hiệu quả, năng suất",
    example: "The new system is more <em>efficient</em> than before.",
    emoji: "⚡"
  },
  {
    word: "Flexible",
    phonetic: "/ˈfleksɪbəl/",
    type: "Tính từ",
    meaning: "Linh hoạt, dẻo dai",
    example: "We need a more <em>flexible</em> work schedule.",
    emoji: "🤸"
  },
  {
    word: "Generate",
    phonetic: "/ˈdʒenəreɪt/",
    type: "Động từ",
    meaning: "Tạo ra, sản sinh",
    example: "Solar panels <em>generate</em> clean electricity.",
    emoji: "⚙️"
  },
  {
    word: "Harmony",
    phonetic: "/ˈhɑːrməni/",
    type: "Danh từ",
    meaning: "Sự hài hòa, sự đồng thuận",
    example: "They lived in perfect <em>harmony</em> with nature.",
    emoji: "🎵"
  },
  {
    word: "Inspire",
    phonetic: "/ɪnˈspaɪər/",
    type: "Động từ",
    meaning: "Truyền cảm hứng",
    example: "Great leaders <em>inspire</em> others to be their best.",
    emoji: "💡"
  },
  {
    word: "Journey",
    phonetic: "/ˈdʒɜːrni/",
    type: "Danh từ",
    meaning: "Hành trình, chuyến đi",
    example: "Learning is a lifelong <em>journey</em> of discovery.",
    emoji: "🗺️"
  }
];

/* ============================================================
   TRẠNG THÁI ỨNG DỤNG
   ============================================================ */
let currentIndex = 0;       // Thẻ đang hiển thị
let isFlipped = false;       // Thẻ đang lật hay không
let cardOrder = [...Array(vocabulary.length).keys()]; // Thứ tự thẻ [0,1,2,...]
let seenCards = new Set();   // Tập hợp thẻ đã xem

/* ============================================================
   KHỞI TẠO ỨNG DỤNG
   ============================================================ */
function init() {
  renderCard();
  renderTable();
  updateProgress();
  updateNavButtons();
}

/* ============================================================
   RENDER FLASHCARD — Cập nhật nội dung thẻ hiện tại
   ============================================================ */
function renderCard() {
  const idx = cardOrder[currentIndex];
  const data = vocabulary[idx];

  // Mặt trước
  document.getElementById('frontWord').textContent = data.word;
  document.getElementById('frontPhonetic').textContent = data.phonetic;

  // Mặt sau
  document.getElementById('backType').textContent = data.type;
  document.getElementById('backMeaning').textContent = data.meaning;
  document.getElementById('backExample').innerHTML = '"' + data.example + '"';
  document.getElementById('backEmoji').textContent = data.emoji;

  // Nếu thẻ đang lật, reset về mặt trước
  if (isFlipped) {
    const card = document.getElementById('flashcard');
    card.classList.remove('is-flipped');
    isFlipped = false;
  }

  // Đánh dấu thẻ đã xem
  seenCards.add(currentIndex);
}

/* ============================================================
   LẬT THẺ — Toggle flip animation
   ============================================================ */
function flipCard() {
  const card = document.getElementById('flashcard');
  isFlipped = !isFlipped;

  // Thêm class is-flipped để CSS xoay 180deg
  card.classList.toggle('is-flipped', isFlipped);
  card.classList.add('animate-flip');
  setTimeout(() => card.classList.remove('animate-flip'), 750);
}

/* ============================================================
   PHÁT ÂM — Dùng Web Speech API (built-in trình duyệt)
   ============================================================ */
function speakWord(event) {
  // Ngăn click lan ra card-scene (tránh flip khi nhấn loa)
  event.stopPropagation();

  const idx = cardOrder[currentIndex];
  const word = vocabulary[idx].word;

  // Web Speech API — không cần thư viện ngoài
  if ('speechSynthesis' in window) {
    const utter = new SpeechSynthesisUtterance(word);
    utter.lang = 'en-US';
    utter.rate = 0.85;  // Tốc độ đọc chậm hơn một chút
    utter.pitch = 1;
    speechSynthesis.cancel(); // Hủy hàng chờ cũ
    speechSynthesis.speak(utter);

    // Visual feedback: nút rung nhẹ
    const btn = document.getElementById('speakBtn');
    btn.style.transform = 'scale(0.93)';
    setTimeout(() => btn.style.transform = '', 150);
  } else {
    alert('Trình duyệt của bạn không hỗ trợ phát âm thanh.');
  }
}

/* ============================================================
   ĐIỀU HƯỚNG — Trước / Tiếp theo
   ============================================================ */
function nextCard() {
  if (currentIndex < vocabulary.length - 1) {
    currentIndex++;
    seenCards.add(currentIndex);
    renderCard();
    updateProgress();
    updateNavButtons();
  }
}

function prevCard() {
  if (currentIndex > 0) {
    currentIndex--;
    renderCard();
    updateProgress();
    updateNavButtons();
  }
}

/* Cập nhật trạng thái disabled của nút Prev/Next */
function updateNavButtons() {
  document.getElementById('prevBtn').disabled = (currentIndex === 0);
  document.getElementById('nextBtn').disabled = (currentIndex === vocabulary.length - 1);
}

/* ============================================================
   XÁO TRỘN — Fisher-Yates shuffle algorithm
   ============================================================ */
function shuffleCards() {
  // Shuffle mảng thứ tự
  for (let i = cardOrder.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [cardOrder[i], cardOrder[j]] = [cardOrder[j], cardOrder[i]];
  }
  // Reset về thẻ đầu tiên sau khi xáo trộn
  currentIndex = 0;
  seenCards = new Set([0]);
  renderCard();
  updateProgress();
  updateNavButtons();
}

/* ============================================================
   THANH TIẾN TRÌNH
   ============================================================ */
function updateProgress() {
  const total = vocabulary.length;
  const seen = seenCards.size;
  const pct = Math.round((seen / total) * 100);

  document.getElementById('progressFill').style.width = pct + '%';
  document.getElementById('progress-label').textContent =
    (currentIndex + 1) + ' / ' + total;
}

/* ============================================================
   RENDER BẢNG TỪ VỰNG
   ============================================================ */
function renderTable(data = vocabulary) {
  const tbody = document.getElementById('wordTableBody');
  tbody.innerHTML = '';

  data.forEach((item, i) => {
    // Tìm index gốc để jump đến đúng thẻ
    const realIdx = vocabulary.indexOf(item);

    const tr = document.createElement('tr');
    tr.innerHTML = `
      <td>${item.word}</td>
      <td>${item.phonetic}</td>
      <td><span class="type-tag">${item.type}</span></td>
      <td>${item.meaning}</td>
      <td style="max-width:200px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">${item.example.replace(/<\/?em>/g,'')}</td>
    `;
    // Click vào hàng → nhảy đến thẻ đó
    tr.onclick = () => {
      const orderIdx = cardOrder.indexOf(realIdx);
      if (orderIdx !== -1) {
        currentIndex = orderIdx;
      } else {
        currentIndex = realIdx;
      }
      seenCards.add(currentIndex);
      renderCard();
      updateProgress();
      updateNavButtons();
      // Cuộn lên khu vực flashcard
      document.getElementById('flashcard-section').scrollIntoView({ behavior: 'smooth' });
    };
    tbody.appendChild(tr);
  });
}

/* ============================================================
   TÌM KIẾM — Filter bảng theo input
   ============================================================ */
function filterTable() {
  const query = document.getElementById('searchInput').value.toLowerCase();
  const filtered = vocabulary.filter(item =>
    item.word.toLowerCase().includes(query) ||
    item.meaning.toLowerCase().includes(query)
  );
  renderTable(filtered);
}

/* ============================================================
   DARK MODE TOGGLE
   ============================================================ */
const themeToggle = document.getElementById('themeToggle');

function toggleTheme() {
  const html = document.documentElement;
  const isDark = html.getAttribute('data-theme') === 'dark';
  html.setAttribute('data-theme', isDark ? 'light' : 'dark');
  themeToggle.textContent = isDark ? '🌙' : '☀️';
  // Lưu preference vào localStorage
  localStorage.setItem('theme', isDark ? 'light' : 'dark');
}

themeToggle.addEventListener('click', toggleTheme);

// Load saved theme khi mở trang
(function loadTheme() {
  const saved = localStorage.getItem('theme');
  if (saved === 'dark') {
    document.documentElement.setAttribute('data-theme', 'dark');
    themeToggle.textContent = '☀️';
  }
})();

/* ============================================================
   MOBILE NAVIGATION TOGGLE
   ============================================================ */
function toggleNav() {
  document.getElementById('navLinks').classList.toggle('is-open');
}

/* ============================================================
   KEYBOARD SHORTCUTS — Điều hướng bằng bàn phím
   ============================================================ */
document.addEventListener('keydown', (e) => {
  switch(e.key) {
    case 'ArrowRight': nextCard(); break;
    case 'ArrowLeft':  prevCard(); break;
    case ' ':          // Space bar = lật thẻ
      e.preventDefault();
      flipCard();
      break;
  }
});

/* ============================================================
   KHỞI CHẠY
   ============================================================ */
init();
</script>
</body>
</html>
